{
  "name": "codebuddy-tutor",
  "displayName": "CodeBuddy Tutor",
  "description": "A Python-first AI coding tutor that turns daily coding mistakes into personalized lessons.",
  "version": "0.6.0",
  "publisher": "your-publisher-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhinow03/Code-Buddy.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codebuddy.openChat",
    "onCommand:codebuddy.askLine",
    "onCommand:codebuddy.hintLine",
    "onCommand:codebuddy.fullSolutionLine",
    "onCommand:codebuddy.reviewLater",
    "onCommand:codebuddy.startDailyReview",
    "onCommand:codebuddy.showMistakeTimeline",
    "onCommand:codebuddy.showLearningMemory",
    "onCommand:codebuddy.clearLearningMemory",
    "onCommand:codebuddy.clearInlineNotes",
    "onCommand:codebuddy.explainSelection",
    "onCommand:codebuddy.setApiKey",
    "onCommand:codebuddy.clearApiKey"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codebuddy.openChat",
        "title": "CodeBuddy: Open Tutor Chat"
      },
      {
        "command": "codebuddy.askLine",
        "title": "CodeBuddy: Ask About This Line"
      },
      {
        "command": "codebuddy.hintLine",
        "title": "CodeBuddy: Hint For This Line"
      },
      {
        "command": "codebuddy.fullSolutionLine",
        "title": "CodeBuddy: Full Solution For This Line"
      },
      {
        "command": "codebuddy.reviewLater",
        "title": "CodeBuddy: Review This Later"
      },
      {
        "command": "codebuddy.startDailyReview",
        "title": "CodeBuddy: Start Daily Review"
      },
      {
        "command": "codebuddy.showMistakeTimeline",
        "title": "CodeBuddy: Show Mistake Timeline"
      },
      {
        "command": "codebuddy.showLearningMemory",
        "title": "CodeBuddy: Show Learning Memory"
      },
      {
        "command": "codebuddy.clearLearningMemory",
        "title": "CodeBuddy: Clear Learning Memory"
      },
      {
        "command": "codebuddy.clearInlineNotes",
        "title": "CodeBuddy: Clear Buddy Comments"
      },
      {
        "command": "codebuddy.explainSelection",
        "title": "CodeBuddy: Ask Selection"
      },
      {
        "command": "codebuddy.setApiKey",
        "title": "CodeBuddy: Set API Key"
      },
      {
        "command": "codebuddy.clearApiKey",
        "title": "CodeBuddy: Clear API Key"
      }
    ],
    "configuration": {
      "title": "CodeBuddy Tutor",
      "properties": {
        "codebuddy.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai",
            "openrouter",
            "local"
          ],
          "default": "anthropic",
          "description": "AI provider used for tutor replies."
        },
        "codebuddy.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional API base URL override. Leave blank to use the provider default."
        },
        "codebuddy.model": {
          "type": "string",
          "default": "",
          "description": "Optional model override. Leave blank to use the provider default."
        },
        "codebuddy.tutorLevel": {
          "type": "string",
          "enum": [
            "beginner",
            "intermediate",
            "advanced"
          ],
          "default": "beginner",
          "description": "How deeply CodeBuddy should explain concepts."
        },
        "codebuddy.maxContextCharacters": {
          "type": "number",
          "default": 6000,
          "minimum": 1000,
          "maximum": 20000,
          "description": "Maximum characters of editor context sent with a question."
        }
      }
    },
    "keybindings": [
      {
        "command": "codebuddy.askLine",
        "key": "ctrl+alt+b",
        "when": "editorTextFocus"
      },
      {
        "command": "codebuddy.clearInlineNotes",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codebuddy.askLine",
          "group": "navigation"
        },
        {
          "command": "codebuddy.hintLine",
          "group": "navigation"
        },
        {
          "command": "codebuddy.fullSolutionLine",
          "group": "navigation"
        },
        {
          "command": "codebuddy.reviewLater",
          "group": "navigation"
        },
        {
          "command": "codebuddy.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "test": "npm run compile && node scripts/smoke-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.5.4"
  }
}
